    <dashboard name='Key Findings' type='storyboard'>
      <style />
      <size maxheight='1164' maxwidth='1216' minheight='1164' minwidth='1216' sizing-mode='fixed' />
      <zones>
        <zone h='100000' id='2' type-v2='layout-basic' w='100000' x='0' y='0'>
          <zone h='98626' id='12' param='vert' removable='false' type-v2='layout-flow' w='98684' x='658' y='687'>
            <zone h='98626' id='1' param='vert' removable='false' type-v2='layout-flow' w='98684' x='658' y='687'>
              <zone h='5412' id='4' paired-zone-id='5' removable='false' type-v2='flipboard-nav' w='98684' x='658' y='687' />
              <zone h='93214' id='5' paired-zone-id='4' removable='false' type-v2='flipboard' w='98684' x='658' y='6099'>
                <flipboard active-id='1' nav-type='dot' show-nav-arrows='true'>
                  <story-points>
                    <story-point captured-sheet='' id='1' />
                  </story-points>
                </flipboard>
              </zone>
            </zone>
          </zone>
          <zone-style>
            <format attr='border-color' value='#000000' />
            <format attr='border-style' value='none' />
            <format attr='border-width' value='0' />
            <format attr='margin' value='8' />
          </zone-style>
        </zone>
        <zone flipboard-zone-id='5' forceUpdate='true' h='17440' id='6' story-point-id='1' type-v2='text' w='92845' x='329' y='4639'>
          <formatted-text>
            <run bold='true' fontcolor='#4e79a7' fontsize='20'>KEY FINDINGS &amp; INSIGHTS</run>
            <run>Æ&#10;</run>
            <run bold='true' fontcolor='#4e79a7' fontsize='20'>Global Space Launch Analytics (1957-2020)</run>
          </formatted-text>
        </zone>
        <zone flipboard-zone-id='5' forceUpdate='true' h='28179' id='7' story-point-id='1' type-v2='text' w='43997' x='493' y='23368'>
          <formatted-text>
            <run fontalignment='0' fontcolor='#666666' fontsize='11'>🔍 FINDING #1: </run>
            <run bold='true' fontalignment='0' fontcolor='#666666' fontsize='11'>Early Soviet Dominance, High Risk</run>
            <run fontalignment='0'>Æ&#10;</run>
            <run fontalignment='0' fontcolor='#666666' fontsize='11'>Æ   </run>
            <run fontalignment='0'>Æ&#10;</run>
            <run fontalignment='0' fontcolor='#666666' fontsize='11'>   This analysis uncovered 4 key insights from 1,614 space launches</run>
            <run fontalignment='0'>Æ&#10;</run>
            <run fontalignment='0' fontcolor='#666666' fontsize='11'>   spanning 1957 - 2020</run>
            <run fontalignment='0'>Æ&#10;&#10;</run>
            <run fontalignment='0' fontcolor='#666666' fontsize='11'>   RVSN USSR conducted 1,600+ launches (30% of global total)</run>
            <run fontalignment='0'>Æ&#10;</run>
            <run fontalignment='0' fontcolor='#666666' fontsize='11'>   BUT had a 15% failure rate vs. Arianespace&apos;s 98% success rate</run>
            <run fontalignment='0'>Æ&#10;</run>
            <run fontalignment='0' fontcolor='#666666' fontsize='11'>Æ   </run>
            <run fontalignment='0'>Æ&#10;</run>
            <run fontalignment='0' fontcolor='#666666' fontsize='11'>   WHY IT MATTERS: </run>
            <run fontalignment='0'>Æ&#10;</run>
            <run fontalignment='0' fontcolor='#666666' fontsize='11'>   Cold War-era (1970s-80s) test launches had quality control issues.</run>
            <run fontalignment='0'>Æ&#10;</run>
            <run fontalignment='0' fontcolor='#666666' fontsize='11'>   Modern commercial space is safer and more reliable.</run>
            <run fontalignment='0'>Æ&#10;</run>
            <run fontalignment='0' fontcolor='#666666' fontsize='11'>Æ   </run>
            <run fontalignment='0'>Æ&#10;</run>
            <run fontalignment='0' fontcolor='#666666' fontsize='11'>   DATA EVIDENCE: Red segment on RVSN bar is largest among all orgs</run>
          </formatted-text>
        </zone>
        <zone flipboard-zone-id='5' forceUpdate='true' h='27921' id='8' story-point-id='1' type-v2='text' w='44161' x='49178' y='23454'>
          <formatted-text>
            <run fontalignment='0' fontcolor='#666666' fontsize='11'>🔍 FINDING #2: </run>
            <run bold='true' fontalignment='0' fontcolor='#666666' fontsize='11'>The Space Race Peaked, Then Collapsed</run>
            <run fontalignment='0'>Æ&#10;</run>
            <run fontalignment='0' fontcolor='#666666' fontsize='11'>Æ   </run>
            <run fontalignment='0'>Æ&#10;</run>
            <run fontalignment='0' fontcolor='#666666' fontsize='11'>   Launch activity peaked at 110+ launches/year in 1973 (Cold War height)</run>
            <run fontalignment='0'>Æ&#10;</run>
            <run fontalignment='0' fontcolor='#666666' fontsize='11'>   Dropped 60% by 2000 (end of Space Shuttle era)</run>
            <run fontalignment='0'>Æ&#10;</run>
            <run fontalignment='0' fontcolor='#666666' fontsize='11'>Æ   </run>
            <run fontalignment='0'>Æ&#10;</run>
            <run fontalignment='0' fontcolor='#666666' fontsize='11'>   KEY EVENTS:</run>
            <run fontalignment='0'>Æ&#10;</run>
            <run fontalignment='0' fontcolor='#666666' fontsize='11'>   • 1986: Challenger Disaster → dip visible in graph</run>
            <run fontalignment='0'>Æ&#10;</run>
            <run fontalignment='0' fontcolor='#666666' fontsize='11'>   • 1993: Russia-US cooperation begins → stabilizes at 40-50/year</run>
            <run fontalignment='0'>Æ&#10;</run>
            <run fontalignment='0' fontcolor='#666666' fontsize='11'>   • 2003: Columbia Disaster → another dip</run>
            <run fontalignment='0'>Æ&#10;</run>
            <run fontalignment='0' fontcolor='#666666' fontsize='11'>   • 2011: Space Shuttle retired → commercial era begins</run>
            <run fontalignment='0'>Æ&#10;</run>
            <run fontalignment='0' fontcolor='#666666' fontsize='11'>Æ   </run>
            <run fontalignment='0'>Æ&#10;</run>
            <run fontalignment='0' fontcolor='#666666' fontsize='11'>   DATA EVIDENCE: See time series chart - clear peaks and valleys</run>
          </formatted-text>
        </zone>
        <zone flipboard-zone-id='5' forceUpdate='true' h='27663' id='9' story-point-id='1' type-v2='text' w='43914' x='576' y='54553'>
          <formatted-text>
            <run fontalignment='0' fontcolor='#666666' fontsize='11'>🔍 FINDING #3: </run>
            <run bold='true' fontalignment='0' fontcolor='#666666' fontsize='11'>Launch Market is Highly Concentrated</run>
            <run fontalignment='0'>Æ&#10;</run>
            <run fontalignment='0' fontcolor='#666666' fontsize='11'>Æ   </run>
            <run fontalignment='0'>Æ&#10;</run>
            <run fontalignment='0' fontcolor='#666666' fontsize='11'>   Only 4 countries account for ~85% of all launches:</run>
            <run fontalignment='0'>Æ&#10;</run>
            <run fontalignment='0' fontcolor='#666666' fontsize='11'>   • Russia (USSR/RVSN): ~45%</run>
            <run fontalignment='0'>Æ&#10;</run>
            <run fontalignment='0' fontcolor='#666666' fontsize='11'>   • USA: ~25%</run>
            <run fontalignment='0'>Æ&#10;</run>
            <run fontalignment='0' fontcolor='#666666' fontsize='11'>   • China: ~10%</run>
            <run fontalignment='0'>Æ&#10;</run>
            <run fontalignment='0' fontcolor='#666666' fontsize='11'>   • Europe (ESA/Arianespace): ~5%</run>
            <run fontalignment='0'>Æ&#10;</run>
            <run fontalignment='0' fontcolor='#666666' fontsize='11'>Æ   </run>
            <run fontalignment='0'>Æ&#10;</run>
            <run fontalignment='0' fontcolor='#666666' fontsize='11'>   IMPLICATION: Limited competition = higher prices (historically)</run>
            <run fontalignment='0'>Æ&#10;</run>
            <run fontalignment='0' fontcolor='#666666' fontsize='11'>   Recent: SpaceX disruption is changing this</run>
            <run fontalignment='0'>Æ&#10;</run>
            <run fontalignment='0' fontcolor='#666666' fontsize='11'>Æ   </run>
            <run fontalignment='0'>Æ&#10;</run>
            <run fontalignment='0' fontcolor='#666666' fontsize='11'>   DATA EVIDENCE: Map shows dark blue (Russia/USA) dominance</run>
          </formatted-text>
        </zone>
        <zone flipboard-zone-id='5' forceUpdate='true' h='27577' id='10' story-point-id='1' type-v2='text' w='44408' x='49095' y='54639'>
          <formatted-text>
            <run fontalignment='0' fontsize='11'>🔍 FINDING #4: </run>
            <run bold='true' fontalignment='0' fontsize='11'>Quality Control Improved Over Time</run>
            <run fontalignment='0'>Æ&#10;</run>
            <run fontalignment='0' fontsize='11'>Æ   </run>
            <run fontalignment='0'>Æ&#10;</run>
            <run fontalignment='0' fontsize='11'>   Pre-1990: ~10% failure rate (early tech, experimental launches)</run>
            <run fontalignment='0'>Æ&#10;</run>
            <run fontalignment='0' fontsize='11'>   2000s: ~5% failure rate (matured technology)</run>
            <run fontalignment='0'>Æ&#10;</run>
            <run fontalignment='0' fontsize='11'>   2010s: ~2% failure rate (commercial competition forces reliability)</run>
            <run fontalignment='0'>Æ&#10;</run>
            <run fontalignment='0' fontsize='11'>Æ   </run>
            <run fontalignment='0'>Æ&#10;</run>
            <run fontalignment='0' fontsize='11'>   RECOMMENDATION: </run>
            <run fontalignment='0'>Æ&#10;</run>
            <run fontalignment='0' fontsize='11'>   Governments should partner with commercial providers </run>
            <run fontalignment='0'>Æ&#10;</run>
            <run fontalignment='0' fontsize='11'>   (Arianespace, SpaceX) for safer, cost-effective launches</run>
            <run fontalignment='0'>Æ&#10;</run>
            <run fontalignment='0' fontsize='11'>Æ   </run>
            <run fontalignment='0'>Æ&#10;</run>
            <run fontalignment='0' fontsize='11'>   DATA EVIDENCE: Failure (red) segments are larger in early years</run>
          </formatted-text>
        </zone>
      </zones>
      <simple-id uuid='{31F4DC7A-128C-40EE-9512-E9D60F19ADF4}' />
    </dashboard>
  </dashboards>
